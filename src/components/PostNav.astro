---
import type { Post } from '../lib/posts';
import { postHref } from '../lib/posts';

interface Props {
  newer?: Post | null;
  older?: Post | null;
}
const { newer = null, older = null } = Astro.props;
---

{
  (newer || older) && (
    <nav
      class="mt-16 grid gap-4 border-t border-default pt-8 sm:grid-cols-2"
      aria-label="上一篇/下一篇"
    >
      {older ? (
        <a href={postHref(older)} class="card group flex flex-col p-4">
          <span class="flex items-center gap-1 text-xs text-faint">
            <span class="arrow arrow--left">←</span> 上一篇（更早）
          </span>
          <span class="mt-1 font-medium transition-colors group-hover:text-accent">
            {older.data.title}
          </span>
        </a>
      ) : (
        <span />
      )}
      {newer ? (
        <a href={postHref(newer)} class="card group flex flex-col p-4 sm:items-end sm:text-right">
          <span class="flex items-center gap-1 text-xs text-faint">
            下一篇（更新） <span class="arrow arrow--right">→</span>
          </span>
          <span class="mt-1 font-medium transition-colors group-hover:text-accent">
            {newer.data.title}
          </span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
