---
import type { Post } from '../lib/posts';
import { postHref } from '../lib/posts';

interface Props {
  newer?: Post | null;
  older?: Post | null;
}
const { newer = null, older = null } = Astro.props;
const cardCls =
  'group flex flex-col rounded-xl border p-4 transition-all hover:-translate-y-0.5';
---

{
  (newer || older) && (
    <nav class="mt-16 grid gap-4 border-t pt-8 sm:grid-cols-2" style="border-color: var(--border)" aria-label="上一篇/下一篇">
      {older ? (
        <a href={postHref(older)} class={cardCls} style="border-color: var(--border)" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
          <span class="text-xs" style="color: var(--text-muted)">← 上一篇（更早）</span>
          <span class="mt-1 font-medium transition-colors group-hover:text-[var(--accent)]">{older.data.title}</span>
        </a>
      ) : (
        <span />
      )}
      {newer ? (
        <a href={postHref(newer)} class={`${cardCls} sm:text-right`} style="border-color: var(--border)" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
          <span class="text-xs" style="color: var(--text-muted)">下一篇（更新）→</span>
          <span class="mt-1 font-medium transition-colors group-hover:text-[var(--accent)]">{newer.data.title}</span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
