---
import type { DayPoint } from '../lib/posts';

interface Props {
  points: DayPoint[];
}
const { points } = Astro.props;

const W = 720;
const H = 240;
const padL = 34;
const padR = 12;
const padT = 14;
const padB = 26;
const innerW = W - padL - padR;
const innerH = H - padT - padB;

const n = points.length;
const maxV = Math.max(1, ...points.map((p) => Math.max(p.pv, p.uv)));

const x = (i: number) => padL + (n <= 1 ? innerW / 2 : (i / (n - 1)) * innerW);
const y = (v: number) => padT + innerH - (v / maxV) * innerH;

const linePath = (key: 'pv' | 'uv') =>
  points.map((p, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)},${y(p[key]).toFixed(1)}`).join(' ');
const pvLine = linePath('pv');
const pvArea = `${pvLine} L${x(n - 1).toFixed(1)},${padT + innerH} L${x(0).toFixed(1)},${padT + innerH} Z`;
const uvLine = linePath('uv');

// y 轴刻度（0 / 中 / max）
const yTicks = [0, Math.round(maxV / 2), maxV].filter((v, i, a) => a.indexOf(v) === i);
// x 轴标签：最多 ~7 个
const step = Math.max(1, Math.ceil(n / 7));
const xLabels = points
  .map((p, i) => ({ i, label: p.date.slice(5) }))
  .filter(({ i }) => i % step === 0 || i === n - 1);

const totalPV = points.reduce((s, p) => s + p.pv, 0);
const totalUV = Math.max(...points.map((p) => p.uv), 0);
---

<div>
  <div class="mb-3 flex items-center gap-5 text-sm">
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-2.5 w-2.5 rounded-full" style="background: var(--accent)"></span>
      PV <span style="color: var(--text-muted)">合计 {totalPV}</span>
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-2.5 w-2.5 rounded-full" style="background: var(--text-muted)"></span>
      UV <span style="color: var(--text-muted)">单日峰值 {totalUV}</span>
    </span>
  </div>

  <svg viewBox={`0 0 ${W} ${H}`} class="w-full" style="height: auto" role="img" aria-label="浏览趋势">
    <defs>
      <linearGradient id="pvfill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--accent)" stop-opacity="0.25"></stop>
        <stop offset="1" stop-color="var(--accent)" stop-opacity="0"></stop>
      </linearGradient>
    </defs>

    {/* 纵向淡网格：落在 x 轴标签位置，增强读数对位 */}
    {
      xLabels.map(({ i }) => (
        <line
          x1={x(i)}
          y1={padT}
          x2={x(i)}
          y2={padT + innerH}
          stroke="var(--border)"
          stroke-width="1"
          stroke-opacity="0.4"
        />
      ))
    }

    {/* 网格 + y 轴刻度 */}
    {
      yTicks.map((v) => (
        <g>
          <line x1={padL} y1={y(v)} x2={W - padR} y2={y(v)} stroke="var(--border)" stroke-width="1" />
          <text x={padL - 6} y={y(v) + 3} text-anchor="end" font-size="10" fill="var(--text-muted)">
            {v}
          </text>
        </g>
      ))
    }

    {/* x 轴标签 */}
    {
      xLabels.map(({ i, label }) => (
        <text x={x(i)} y={H - 8} text-anchor="middle" font-size="10" fill="var(--text-muted)">
          {label}
        </text>
      ))
    }

    {/* PV 面积 + 线 */}
    <path d={pvArea} fill="url(#pvfill)"></path>
    <path d={pvLine} fill="none" stroke="var(--accent)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"></path>
    {/* UV 线（虚线） */}
    <path d={uvLine} fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-dasharray="4 3" stroke-linejoin="round"></path>

    {/* 数据点 + 悬停提示（hover 放大） */}
    {
      points.map((p, i) => (
        <circle class="chart-dot" cx={x(i)} cy={y(p.pv)} r="2" fill="var(--accent)">
          <title>{`${p.date}  PV ${p.pv} · UV ${p.uv}`}</title>
        </circle>
      ))
    }
  </svg>
</div>

<style>
  /* 数据点默认更小，hover 放大更精致（r 在现代浏览器可过渡） */
  .chart-dot {
    cursor: pointer;
    transition: r var(--dur-fast) var(--ease-out);
  }
  .chart-dot:hover {
    r: 5;
  }
</style>
