---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
// 只取 h2 / h3 做目录
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <>
      {/* 宽屏：右侧浮动目录 */}
      <nav class="toc" aria-label="文章目录">
        <p class="mb-2 text-xs font-semibold uppercase tracking-wide" style="color: var(--text-muted)">
          目录
        </p>
        {items.map((h) => (
          <a href={`#${h.slug}`} class={`toc-link depth-${h.depth}`} data-slug={h.slug}>
            {h.text}
          </a>
        ))}
      </nav>

      {/* 窄屏：正文顶部可折叠目录 */}
      <details class="toc-inline">
        <summary>目录</summary>
        <div class="mt-2">
          {items.map((h) => (
            <a href={`#${h.slug}`} class={`toc-link depth-${h.depth}`} data-slug={h.slug}>
              {h.text}
            </a>
          ))}
        </div>
      </details>
    </>
  )
}

<script>
  function setupToc() {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-link'));
    if (links.length === 0) return;

    const seen = new Set<string>();
    const headings = links
      .map((l) => l.dataset.slug || '')
      .filter((slug) => slug && !seen.has(slug) && seen.add(slug))
      .map((slug) => document.getElementById(slug))
      .filter((el): el is HTMLElement => el !== null);

    const setActive = (id: string) => {
      links.forEach((l) => l.classList.toggle('active', l.dataset.slug === id));
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: '0px 0px -75% 0px', threshold: 0 }
    );
    headings.forEach((h) => observer.observe(h));

    // 点击窄屏目录后自动收起
    document.querySelectorAll('.toc-inline a').forEach((a) => {
      a.addEventListener('click', () => {
        const d = a.closest('details');
        if (d) d.open = false;
      });
    });
  }
  setupToc();
  document.addEventListener('astro:after-swap', setupToc);
</script>
