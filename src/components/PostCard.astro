---
import FormattedDate from './FormattedDate.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  cover?: string;
  category?: string;
  minutes?: number;
}
const { href, title, description, pubDate, tags = [], cover, category, minutes } = Astro.props;
---

<a href={href} class="card card--glow group overflow-hidden">
  {
    cover && (
      <div class="overflow-hidden">
        <img
          src={cover}
          alt={title}
          class="h-44 w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
        />
      </div>
    )
  }
  <div class="p-5">
    <div class="mb-2 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-faint">
      {category && <span class="chip chip--accent">{category}</span>}
      <FormattedDate date={pubDate} />
      {
        tags.length > 0 && (
          <span class="flex gap-2">
            {tags.slice(0, 3).map((t) => (
              <span>#{t}</span>
            ))}
          </span>
        )
      }
      {typeof minutes === 'number' && <span>⏱ {minutes} 分钟</span>}
    </div>
    <h3 class="mb-1 text-lg font-semibold tracking-tight transition-colors group-hover:text-accent">
      {title}
    </h3>
    <p class="line-clamp-2 text-sm leading-relaxed text-muted">
      {description}
    </p>
  </div>
</a>
