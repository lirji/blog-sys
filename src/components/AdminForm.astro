---
import type { Post } from '../lib/posts';

interface Props {
  post?: Post | null;
  submitLabel: string;
  error?: string;
}
const { post = null, submitLabel, error = '' } = Astro.props;
const d = post?.data;
const dateValue = d?.pubDate ? new Date(d.pubDate).toISOString().slice(0, 10) : '';
const inputCls =
  'w-full rounded-lg border bg-transparent px-3 py-2 outline-none focus:border-[var(--accent)]';
---

<form method="POST" class="space-y-5">
  {error && (
    <p class="rounded-lg px-4 py-2 text-sm" style="background: color-mix(in oklch, #ef4444 15%, transparent); color: #ef4444">{error}</p>
  )}

  <div>
    <label class="mb-1 block text-sm font-medium">标题 *</label>
    <input name="title" value={d?.title ?? ''} required class={inputCls} style="border-color: var(--border)" />
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label class="mb-1 block text-sm font-medium">Slug（URL） *</label>
      <input name="slug" value={post?.slug ?? ''} required placeholder="my-post" class={inputCls} style="border-color: var(--border)" />
    </div>
    <div>
      <label class="mb-1 block text-sm font-medium">分类</label>
      <input name="category" value={d?.category ?? ''} placeholder="随笔" class={inputCls} style="border-color: var(--border)" />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label class="mb-1 block text-sm font-medium">标签（逗号分隔）</label>
      <input name="tags" value={d?.tags?.join(', ') ?? ''} placeholder="后端, 分布式" class={inputCls} style="border-color: var(--border)" />
    </div>
    <div>
      <label class="mb-1 block text-sm font-medium">发布日期</label>
      <input type="date" name="pubDate" value={dateValue} class={inputCls} style="border-color: var(--border)" />
    </div>
  </div>

  <div>
    <label class="mb-1 block text-sm font-medium">封面图 URL（可选）</label>
    <input name="cover" value={d?.cover ?? ''} placeholder="/covers/xxx.svg" class={inputCls} style="border-color: var(--border)" />
  </div>

  <div>
    <label class="mb-1 block text-sm font-medium">摘要</label>
    <textarea name="description" rows="2" class={inputCls} style="border-color: var(--border)">{d?.description ?? ''}</textarea>
  </div>

  <div>
    <label class="mb-1 block text-sm font-medium">正文（Markdown）</label>
    <textarea name="body" rows="18" class={`${inputCls} font-mono text-sm`} style="border-color: var(--border)">{post?.body ?? ''}</textarea>
  </div>

  <label class="flex items-center gap-2 text-sm">
    <input type="checkbox" name="draft" checked={d?.draft ?? false} />
    存为草稿（不在站点公开显示）
  </label>

  <div class="flex gap-3">
    <button type="submit" class="rounded-lg px-5 py-2.5 font-medium text-white transition-transform hover:-translate-y-0.5" style="background: var(--accent)">
      {submitLabel}
    </button>
    <a href="/admin" class="rounded-lg border px-5 py-2.5 font-medium transition-colors hover:bg-[var(--bg-soft)]" style="border-color: var(--border)">
      取消
    </a>
  </div>
</form>
