---
import type { Post } from '../lib/posts';

interface Props {
  post?: Post | null;
  submitLabel: string;
  error?: string;
}
const { post = null, submitLabel, error = '' } = Astro.props;
const d = post?.data;
const dateValue = d?.pubDate ? new Date(d.pubDate).toISOString().slice(0, 10) : '';
// 统一表单控件样式（圆角 + 边框 + 聚焦 accent 光环），见 global.css 的 .admin-input。
// 注意：套用 .admin-input 的元素不要再写内联 border-color，否则会盖过聚焦描边。
const inputCls = 'admin-input';
---

<form method="POST" class="space-y-5">
  {error && (
    <p
      class="flex items-center gap-2 rounded-md px-4 py-2.5 text-sm"
      style="background: color-mix(in oklch, #ef4444 14%, transparent); color: #ef4444"
    >
      <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.008M10.34 3.94 1.94 18a1.5 1.5 0 0 0 1.3 2.25h17.52a1.5 1.5 0 0 0 1.3-2.25L13.66 3.94a1.5 1.5 0 0 0-2.6 0Z" />
      </svg>
      {error}
    </p>
  )}

  <div>
    <label class="mb-1.5 block text-sm font-medium text-fg">标题 *</label>
    <input name="title" value={d?.title ?? ''} required class={inputCls} />
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label class="mb-1.5 block text-sm font-medium text-fg">Slug（URL） *</label>
      <input name="slug" value={post?.slug ?? ''} required placeholder="my-post" class={inputCls} />
    </div>
    <div>
      <label class="mb-1.5 block text-sm font-medium text-fg">分类</label>
      <input name="category" value={d?.category ?? ''} placeholder="随笔" class={inputCls} />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label class="mb-1.5 block text-sm font-medium text-fg">标签（逗号分隔）</label>
      <input name="tags" value={d?.tags?.join(', ') ?? ''} placeholder="后端, 分布式" class={inputCls} />
    </div>
    <div>
      <label class="mb-1.5 block text-sm font-medium text-fg">发布日期</label>
      <input type="date" name="pubDate" value={dateValue} class={inputCls} />
    </div>
  </div>

  <div>
    <label class="mb-1.5 block text-sm font-medium text-fg">封面图（可选）</label>
    <div class="flex gap-2">
      <input id="cover-input" name="cover" value={d?.cover ?? ''} placeholder="/media/1 或直接上传" class={inputCls} />
      <button type="button" id="cover-upload-btn" class="btn btn--ghost btn--sm shrink-0">上传</button>
      <input type="file" id="cover-file" accept="image/*" class="hidden" />
    </div>
  </div>

  <div>
    <label class="mb-1.5 block text-sm font-medium text-fg">摘要</label>
    <textarea name="description" rows="2" class={inputCls}>{d?.description ?? ''}</textarea>
  </div>

  <div>
    <div class="mb-1.5 flex items-center justify-between">
      <label class="block text-sm font-medium text-fg">正文（Markdown）</label>
      <div class="flex items-center gap-3 text-xs text-faint">
        <button type="button" id="body-upload-btn" class="btn btn--ghost btn--sm">🖼 插入图片</button>
        <span class="hidden sm:inline">也可直接把图片拖入 / 粘贴到编辑区</span>
      </div>
    </div>
    <input type="file" id="body-file" accept="image/*" class="hidden" />
    <div class="grid gap-4 lg:grid-cols-2">
      <textarea
        id="body-editor"
        name="body"
        rows="22"
        class={`${inputCls} font-mono text-sm`}
        spellcheck="false">{post?.body ?? ''}</textarea>
      <div
        id="body-preview"
        class="prose max-w-none overflow-auto border border-default p-4"
        style="border-radius: var(--rad-md); background: var(--bg-soft); max-height: 40rem"
      >
      </div>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm text-fg">
    <input type="checkbox" name="draft" checked={d?.draft ?? false} style="accent-color: var(--accent)" />
    存为草稿（不在站点公开显示）
  </label>

  <div class="flex gap-3">
    <button type="submit" class="btn btn--primary">{submitLabel}</button>
    <a href="/admin" class="btn btn--ghost">取消</a>
  </div>
</form>

<script>
  const editor = document.getElementById('body-editor') as HTMLTextAreaElement | null;
  const preview = document.getElementById('body-preview') as HTMLElement | null;

  // ---- 实时预览（复用服务端同一套渲染，所见即所得）----
  if (editor && preview) {
    let timer: ReturnType<typeof setTimeout>;
    const render = async () => {
      try {
        const res = await fetch('/admin/preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ markdown: editor.value }),
        });
        preview.innerHTML = await res.text();
      } catch {
        /* 忽略预览错误 */
      }
    };
    editor.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(render, 250);
    });
    render();

    // 拖拽 / 粘贴图片
    editor.addEventListener('paste', (e) => {
      const items = e.clipboardData?.items ?? [];
      for (const it of items) {
        if (it.type.startsWith('image/')) {
          e.preventDefault();
          const f = it.getAsFile();
          if (f) uploadInto(editor, f);
        }
      }
    });
    editor.addEventListener('dragover', (e) => e.preventDefault());
    editor.addEventListener('drop', (e) => {
      const f = e.dataTransfer?.files?.[0];
      if (f && f.type.startsWith('image/')) {
        e.preventDefault();
        uploadInto(editor, f);
      }
    });
  }

  // ---- 上传公共逻辑 ----
  async function upload(file: File): Promise<string | null> {
    const fd = new FormData();
    fd.append('file', file);
    const res = await fetch('/admin/upload', { method: 'POST', body: fd });
    if (!res.ok) {
      const { error } = await res.json().catch(() => ({ error: '上传失败' }));
      alert('上传失败：' + error);
      return null;
    }
    const { url } = await res.json();
    return url as string;
  }

  function insertAtCursor(ta: HTMLTextAreaElement, text: string) {
    const s = ta.selectionStart;
    const e = ta.selectionEnd;
    ta.value = ta.value.slice(0, s) + text + ta.value.slice(e);
    ta.selectionStart = ta.selectionEnd = s + text.length;
    ta.focus();
  }

  async function uploadInto(ta: HTMLTextAreaElement, file: File) {
    const url = await upload(file);
    if (!url) return;
    insertAtCursor(ta, `![${file.name}](${url})\n`);
    ta.dispatchEvent(new Event('input'));
  }

  // 正文插入图片按钮
  const bodyBtn = document.getElementById('body-upload-btn');
  const bodyFile = document.getElementById('body-file') as HTMLInputElement | null;
  bodyBtn?.addEventListener('click', () => bodyFile?.click());
  bodyFile?.addEventListener('change', () => {
    const f = bodyFile.files?.[0];
    if (f && editor) uploadInto(editor, f);
    bodyFile.value = '';
  });

  // 封面上传按钮
  const coverBtn = document.getElementById('cover-upload-btn');
  const coverFile = document.getElementById('cover-file') as HTMLInputElement | null;
  const coverInput = document.getElementById('cover-input') as HTMLInputElement | null;
  coverBtn?.addEventListener('click', () => coverFile?.click());
  coverFile?.addEventListener('change', async () => {
    const f = coverFile.files?.[0];
    if (f) {
      const url = await upload(f);
      if (url && coverInput) coverInput.value = url;
    }
    coverFile.value = '';
  });
</script>
