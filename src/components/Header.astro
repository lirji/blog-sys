---
import { SITE_TITLE, NAV_LINKS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-md"
  style="border-color: var(--border); background: color-mix(in oklch, var(--bg) 80%, transparent)"
>
  <nav class="mx-auto flex h-16 max-w-3xl items-center justify-between px-5">
    <a href="/" class="text-base font-semibold tracking-tight transition-opacity hover:opacity-70">
      {SITE_TITLE}
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="rounded-lg px-3 py-1.5 text-sm transition-colors hover:bg-[var(--bg-soft)]"
            style={isActive(link.href) ? 'color: var(--accent); font-weight: 600' : 'color: var(--text-muted)'}
          >
            {link.label}
          </a>
        ))
      }
      <div class="ml-1"><ThemeToggle /></div>
    </div>
  </nav>
</header>
