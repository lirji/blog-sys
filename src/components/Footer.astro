---
import { SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="border-color: var(--border)">
  <div
    class="mx-auto flex max-w-3xl flex-col items-center justify-between gap-4 px-5 py-10 text-sm sm:flex-row"
    style="color: var(--text-muted)"
  >
    <p>© {year} {SITE_AUTHOR}</p>
    <div class="flex items-center gap-4">
      {
        SOCIAL_LINKS.map((link) => (
          <a href={link.href} class="transition-colors hover:text-[var(--accent)]" target="_blank" rel="noopener">
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
