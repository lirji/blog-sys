---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { searchPosts, postHref, getCategory } from '../lib/posts';
import { highlight, snippet } from '../lib/highlight';

const q = (Astro.url.searchParams.get('q') ?? '').trim();
const results = q ? await searchPosts(q) : [];
---

<BaseLayout title="搜索">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">搜索</h1>
  </div>

  <form method="GET" action="/search" class="mb-8">
    <div class="relative">
      <svg
        class="pointer-events-none absolute left-3.5 top-1/2 h-5 w-5 -translate-y-1/2 text-faint"
        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M17 10.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" />
      </svg>
      <input
        type="search"
        name="q"
        value={q}
        placeholder="输入关键词，回车搜索…"
        autofocus
        class="search-input w-full rounded-lg border border-default py-3 pl-11 pr-4 text-fg outline-none"
        style="background: var(--card)"
      />
    </div>
  </form>

  {
    q && (
      <p class="mb-6 text-sm text-faint">
        关键词「{q}」找到 {results.length} 篇。
      </p>
    )
  }

  <div class="grid gap-4">
    {
      results.map((post, i) => (
        <div class="reveal" style={`--i:${Math.min(i, 8)}`}>
          <a href={postHref(post)} class="card group block p-6">
            <div class="mb-2 flex items-center gap-3 text-xs text-faint">
              <span class="chip chip--accent">{getCategory(post)}</span>
              <FormattedDate date={post.data.pubDate} />
            </div>
            <h3
              class="mb-1.5 text-lg font-semibold tracking-tight transition-colors group-hover:text-accent"
              set:html={highlight(post.data.title, q)}
            />
            <p class="text-sm leading-relaxed text-muted" set:html={highlight(post.data.description, q)} />
            <p class="mt-2 text-sm leading-relaxed text-muted" set:html={snippet(post.body, q)} />
          </a>
        </div>
      ))
    }
  </div>

  {
    q && results.length === 0 && (
      <div class="py-16 text-center">
        <svg
          class="mx-auto h-12 w-12 text-faint opacity-60"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M17 10.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" />
        </svg>
        <p class="mt-4 text-muted">没有匹配「{q}」的文章，换个词试试。</p>
      </div>
    )
  }
</BaseLayout>
