---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, groupByCategory } from '../../lib/posts';

const categories = groupByCategory(await getPublishedPosts());
---

<BaseLayout title="分类">
  <div class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">分类</h1>
    <p class="mt-2" style="color: var(--text-muted)">按文件夹分类浏览文章。</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {
      categories.map(([category, posts]) => (
        <a
          href={`/categories/${category}/`}
          class="group flex items-center justify-between rounded-2xl border p-6 transition-all hover:-translate-y-0.5"
          style="border-color: var(--border); background: var(--card)"
          onmouseover="this.style.borderColor='var(--accent)'"
          onmouseout="this.style.borderColor='var(--border)'"
        >
          <span class="text-lg font-semibold tracking-tight transition-colors group-hover:text-[var(--accent)]">
            {category}
          </span>
          <span class="text-sm" style="color: var(--text-muted)">
            {posts.length} 篇
          </span>
        </a>
      ))
    }
  </div>
</BaseLayout>
