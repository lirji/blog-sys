---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, groupByCategory } from '../../lib/posts';

const categories = groupByCategory(await getPublishedPosts());
---

<BaseLayout title="分类">
  <div class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">分类</h1>
    <p class="mt-2 text-muted">按文件夹分类浏览文章。</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {
      categories.map(([category, posts], i) => (
        <div class="reveal" style={`--i:${Math.min(i, 8)}`}>
          <a
            href={`/categories/${category}/`}
            class="card group flex items-center justify-between p-6"
          >
            <span class="text-lg font-semibold tracking-tight transition-colors group-hover:text-accent">
              {category}
            </span>
            <span class="flex items-center gap-3">
              <span class="chip">{posts.length} 篇</span>
              <span class="arrow arrow--right text-faint">→</span>
            </span>
          </a>
        </div>
      ))
    }
  </div>
</BaseLayout>
