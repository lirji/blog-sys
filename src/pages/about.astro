---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../consts';

// 社交链接图标（按 label 匹配，未知则用通用外链图标）
function iconFor(label: string) {
  if (/github/i.test(label)) return 'github';
  if (/mail|email|邮/i.test(label)) return 'mail';
  return 'link';
}
---

<BaseLayout title="关于">
  <section class="hero mb-10">
    <div class="flex items-center gap-5">
      <div class="monogram h-16 w-16 shrink-0 text-2xl">李</div>
      <div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">关于我</h1>
        <p class="mt-1 text-muted">后端工程师 · 写点技术与随笔</p>
      </div>
    </div>
  </section>

  <div class="prose prose-lg max-w-none">
    <p>你好，我是李睿君，一名后端工程师，主要玩 Java / Spring 全家桶，也在折腾 Flink、规则引擎和推荐系统。</p>
    <p>这个博客是我沉淀技术笔记和想法的地方。相信<strong>简单</strong>是一种奢侈品，无论写代码还是做产品。</p>

    <h2>你会在这里看到</h2>
    <ul>
      <li>后端工程实践：并发、事务、一致性</li>
      <li>系统设计与架构取舍</li>
      <li>一些不太正经的随笔</li>
    </ul>
  </div>

  <h2 class="mt-12 mb-4 text-xl font-semibold tracking-tight">联系我</h2>
  <div class="flex flex-wrap gap-3">
    {
      SOCIAL_LINKS.map((link) => {
        const icon = iconFor(link.label);
        return (
          <a href={link.href} target="_blank" rel="noopener" class="btn btn--ghost">
            {icon === 'github' && (
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.55-1.14-4.55-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.35 9.35 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.81 0 .27.18.59.69.49A10.03 10.03 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z" />
              </svg>
            )}
            {icon === 'mail' && (
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 6.5h18v11H3z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="m3.5 7 8.5 6 8.5-6" />
              </svg>
            )}
            {icon === 'link' && (
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5 21 3m0 0h-5m5 0v5M10.5 6H6a3 3 0 0 0-3 3v9a3 3 0 0 0 3 3h9a3 3 0 0 0 3-3v-4.5" />
              </svg>
            )}
            <span>{link.label}</span>
          </a>
        );
      })
    }
  </div>
</BaseLayout>
