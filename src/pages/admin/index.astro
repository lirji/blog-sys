---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getPostsPage, getAllCategories, deletePost } from '../../lib/posts';

const PAGE_SIZE = 10;

// 删除后回到原来的分页/筛选
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (form.get('_action') === 'delete') {
    const id = Number(form.get('id'));
    if (id) await deletePost(id);
  }
  const back = Astro.request.headers.get('referer') ?? '/admin';
  return Astro.redirect(back);
}

const params = Astro.url.searchParams;
const category = params.get('category') ?? '';
const page = Number(params.get('page')) || 1;

const { items, total, totalPages } = await getPostsPage({
  page,
  pageSize: PAGE_SIZE,
  category: category || undefined,
});
const categories = await getAllCategories();
const fmt = (d: Date) => new Date(d).toISOString().slice(0, 10);

// 保留 category 的分页链接
const pageUrl = (p: number) =>
  `/admin?${new URLSearchParams({ ...(category ? { category } : {}), page: String(p) })}`;
const catUrl = (c: string) => (c ? `/admin?category=${encodeURIComponent(c)}` : '/admin');
---

<AdminLayout title="文章列表">
  <div class="reveal mb-6 flex items-center justify-between" style="--i:0">
    <h1 class="text-2xl font-bold tracking-tight text-fg">
      文章 <span class="text-muted">（{total}）</span>
    </h1>
    <a href="/admin/new" class="btn btn--primary">
      <span aria-hidden="true">+</span> 新建文章
    </a>
  </div>

  {/* 分类筛选 */}
  <div class="reveal mb-6 flex flex-wrap gap-2" style="--i:1">
    <a href="/admin" class:list={['chip', !category && 'chip--accent']}>全部</a>
    {
      categories.map((c) => (
        <a href={catUrl(c.category)} class:list={['chip', category === c.category && 'chip--accent']}>
          {c.category} <span class="text-faint">{c.count}</span>
        </a>
      ))
    }
  </div>

  <div class="admin-panel reveal overflow-hidden" style="--i:2">
    {
      items.length === 0 ? (
        <p class="p-8 text-center text-sm text-muted">没有文章。</p>
      ) : (
        items.map((post) => (
          <div class="flex items-center justify-between gap-4 border-b border-default px-5 py-4 transition-colors last:border-b-0 hover:bg-bg-soft">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <a href={`/admin/edit/${post.id}`} class="truncate font-medium text-fg transition-colors hover:text-accent">
                  {post.data.title}
                </a>
                {post.data.draft && <span class="chip shrink-0">草稿</span>}
              </div>
              <p class="mt-1 text-xs text-faint">
                {post.data.category} · {fmt(post.data.pubDate)} · 👁 {post.data.views} · /blog/{post.slug}
              </p>
            </div>
            <div class="flex shrink-0 items-center gap-1 text-sm">
              <a
                href={`/blog/${post.slug}/`}
                target="_blank"
                class="rounded-md px-2.5 py-1 text-muted transition-colors hover:bg-bg-subtle hover:text-fg"
              >
                查看
              </a>
              <a
                href={`/admin/edit/${post.id}`}
                class="rounded-md px-2.5 py-1 text-accent transition-colors hover:bg-accent-soft"
              >
                编辑
              </a>
              <form method="POST" onsubmit="return confirm('确定删除这篇文章？')">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={post.id} />
                <button type="submit" class="act-delete rounded-md px-2.5 py-1">删除</button>
              </form>
            </div>
          </div>
        ))
      )
    }
  </div>

  {/* 分页 */}
  {
    totalPages > 1 && (
      <div class="mt-6 flex items-center justify-center gap-4 text-sm">
        {page > 1 ? (
          <a href={pageUrl(page - 1)} class="btn btn--ghost btn--sm">
            <span aria-hidden="true">←</span> 上一页
          </a>
        ) : (
          <span class="btn btn--ghost btn--sm cursor-not-allowed opacity-40">← 上一页</span>
        )}
        <span class="text-muted">第 {page} / {totalPages} 页</span>
        {page < totalPages ? (
          <a href={pageUrl(page + 1)} class="btn btn--ghost btn--sm">
            下一页 <span class="arrow arrow--right">→</span>
          </a>
        ) : (
          <span class="btn btn--ghost btn--sm cursor-not-allowed opacity-40">下一页 →</span>
        )}
      </div>
    )
  }
</AdminLayout>
