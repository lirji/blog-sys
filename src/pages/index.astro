---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getPublishedPosts, getPopularPosts, postHref, getCategory } from '../lib/posts';

const posts = (await getPublishedPosts()).slice(0, 4);
const popular = await getPopularPosts(5);
---

<BaseLayout>
  <section class="pt-8 pb-16 sm:pt-16">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      你好，我是<span style="color: var(--accent)">李睿君</span> 👋
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed" style="color: var(--text-muted)">
      {SITE_DESCRIPTION}这里是我沉淀想法的角落，聊后端工程、系统设计，偶尔也写点随笔。
    </p>
    <div class="mt-8 flex gap-3">
      <a
        href="/blog"
        class="rounded-xl px-5 py-2.5 text-sm font-medium text-white transition-transform hover:-translate-y-0.5"
        style="background: var(--accent)"
      >
        浏览文章
      </a>
      <a
        href="/about"
        class="rounded-xl border px-5 py-2.5 text-sm font-medium transition-colors hover:bg-[var(--bg-soft)]"
        style="border-color: var(--border)"
      >
        关于我
      </a>
    </div>
  </section>

  <section>
    <div class="mb-6 flex items-baseline justify-between">
      <h2 class="text-xl font-semibold tracking-tight">最近的文章</h2>
      <a href="/blog" class="text-sm transition-colors hover:text-[var(--accent)]" style="color: var(--text-muted)">
        全部 →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        posts.map((post) => (
          <PostCard
            href={postHref(post)}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            cover={post.data.cover}
            category={getCategory(post)}
          />
        ))
      }
    </div>
  </section>

  {
    popular.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-xl font-semibold tracking-tight">🔥 热门文章</h2>
        <ol class="overflow-hidden rounded-2xl border" style="border-color: var(--border); background: var(--card)">
          {popular.map((post, i) => (
            <li>
              <a
                href={postHref(post)}
                class="group flex items-center gap-4 border-b px-5 py-3.5 last:border-b-0 transition-colors hover:bg-[var(--bg-soft)]"
                style="border-color: var(--border)"
              >
                <span
                  class="w-6 shrink-0 text-center text-lg font-bold"
                  style={i < 3 ? 'color: var(--accent)' : 'color: var(--text-muted)'}
                >
                  {i + 1}
                </span>
                <span class="min-w-0 flex-1 truncate font-medium transition-colors group-hover:text-[var(--accent)]">
                  {post.data.title}
                </span>
                <span class="shrink-0 text-xs" style="color: var(--text-muted)">
                  👁 {post.data.views}
                </span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )
  }
</BaseLayout>
