---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  cover?: string;
  category?: string;
  headings?: Heading[];
}
const { title, description, pubDate, updatedDate, tags = [], cover, category, headings = [] } =
  Astro.props;
---

<BaseLayout title={title} description={description}>
  <ReadingProgress />
  <TableOfContents headings={headings} />

  <article>
    <a
      href="/blog"
      class="mb-8 inline-flex items-center gap-1 text-sm transition-colors hover:text-[var(--accent)]"
      style="color: var(--text-muted)"
    >
      ← 返回文章列表
    </a>

    <header class="mb-10">
      <div class="mb-3 flex flex-wrap items-center gap-3 text-sm" style="color: var(--text-muted)">
        {
          category && (
            <a
              href={`/categories/${category}/`}
              class="font-medium transition-colors hover:opacity-80"
              style="color: var(--accent)"
            >
              {category}
            </a>
          )
        }
        <FormattedDate date={pubDate} />
        {updatedDate && <span>· 更新于 <FormattedDate date={updatedDate} /></span>}
      </div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <p class="mt-3 text-lg leading-relaxed" style="color: var(--text-muted)">{description}</p>
      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((t) => (
              <a
                href={`/tags/${t}/`}
                class="rounded-full px-3 py-1 text-xs transition-colors hover:text-[var(--accent)]"
                style="background: var(--bg-soft); color: var(--text-muted)"
              >
                #{t}
              </a>
            ))}
          </div>
        )
      }
      {cover && <img src={cover} alt={title} class="cover-img mt-8" />}
    </header>

    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
