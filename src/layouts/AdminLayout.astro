---
import '@fontsource-variable/inter';
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title?: string;
  showNav?: boolean;
}
const { title = '后台', showNav = true } = Astro.props;

// 当前路由高亮：文章（含新建/编辑）、导入、看板
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/admin';
const isPosts =
  pathname === '/admin' || pathname.startsWith('/admin/new') || pathname.startsWith('/admin/edit');
const navItems = [
  { href: '/admin', label: '文章', active: isPosts },
  { href: '/admin/import', label: '导入', active: pathname.startsWith('/admin/import') },
  { href: '/admin/dashboard', label: '看板', active: pathname.startsWith('/admin/dashboard') },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · {SITE_TITLE} 后台</title>
    <script is:inline>
      // 首帧同步定主题，杜绝暗色闪烁
      (() => {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) document.documentElement.classList.add('dark');
      })();
    </script>
    {/* 无 JS 兜底：直接显示 reveal 内容，避免动画依赖导致内容不可见 */}
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    {
      showNav && (
        <header
          id="admin-header"
          class="sticky top-0 z-50 border-b border-default"
          style="background: color-mix(in oklch, var(--bg) 72%, transparent); backdrop-filter: blur(12px) saturate(180%); -webkit-backdrop-filter: blur(12px) saturate(180%)"
        >
          <div class="mx-auto flex h-16 max-w-4xl items-center justify-between gap-3 px-5">
            <div class="flex min-w-0 items-center gap-5">
              <a
                href="/admin"
                class="flex items-center gap-2.5 text-base font-semibold tracking-tight transition-opacity hover:opacity-80"
              >
                <span
                  class="grid h-7 w-7 place-items-center rounded-md text-sm font-bold"
                  style="background: linear-gradient(135deg, var(--accent), oklch(0.62 0.17 320)); color: var(--on-accent)"
                  aria-hidden="true"
                >
                  管
                </span>
                <span>管理后台</span>
              </a>
              <nav class="flex items-center gap-1">
                {navItems.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'relative rounded-lg px-3 py-1.5 text-sm transition-colors',
                      item.active ? 'font-semibold text-accent' : 'text-muted hover:text-fg',
                    ]}
                  >
                    {item.label}
                    {item.active && (
                      <span
                        class="absolute inset-x-3 -bottom-px h-0.5 rounded-full"
                        style="background: var(--accent)"
                        aria-hidden="true"
                      />
                    )}
                  </a>
                ))}
              </nav>
            </div>
            <div class="flex shrink-0 items-center gap-2">
              <a
                href="/"
                target="_blank"
                class="btn btn--ghost btn--sm hidden sm:inline-flex"
              >
                查看站点 <span class="arrow arrow--right">↗</span>
              </a>
              <form method="POST" action="/admin/logout">
                <button type="submit" class="btn btn--ghost btn--sm">退出</button>
              </form>
              <ThemeToggle />
            </div>
          </div>
        </header>
      )
    }
    <main class="mx-auto max-w-4xl px-5 py-10">
      <slot />
    </main>

    {/* 滚动后给后台导航栏加阴影 / 加深边框（与前台 Header 一致） */}
    <script>
      const header = document.getElementById('admin-header');
      if (header) {
        const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8);
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    </script>

    {/* 进入视口时逐个揭示（stagger reveal）；后台无 ClientRouter，故无需 after-swap */}
    <script>
      const els = document.querySelectorAll('.reveal:not(.is-visible)');
      if (els.length) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                obs.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
